generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CampaignStatus {
  ACTIVE
  PAUSED
  REVIEW
}

enum AutopostTargetPlatform {
  TELEGRAM
  DISCORD
  TWITTER
}

enum AutopostScheduleStatus {
  DRAFT
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
}

enum AutopostDeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum InviteEventType {
  LINK_CREATED
  USER_JOINED
  USER_LEFT
  JOIN_REQUEST
}

enum EventTone {
  PRIMARY
  SUCCESS
  WARNING
  DANGER
}

enum SpamDecision {
  ALLOW
  REVIEW
  WARN
  RESTRICT
  BAN
}

enum ModerationScopeType {
  GLOBAL
  GROUP
}

enum ModerationListMode {
  BLOCK
  ALLOW
}

enum UserStatus {
  ACTIVE
  AWAY
  DISABLED
}

enum SystemLogLevel {
  INFO
  WARN
  ERROR
}

enum ContactImportBatchStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

enum ContactImportItemStatus {
  PENDING
  PROCESSING
  RESOLVED
  SKIPPED
  FAILED
}

enum ContactImportItemKind {
  CONTACT
  FREQUENT
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  username     String?    @unique
  name         String
  department   String?
  status       UserStatus @default(ACTIVE)
  passwordHash String
  createdAt    DateTime   @default(now())
  userRoles    UserRole[]
  workspaceMemberships WorkspaceMembership[]
  campaigns    Campaign[] @relation("CampaignAssignee")
  contactImportBatches ContactImportBatch[] @relation("ContactImportCreatedBy")
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String
  createdAt       DateTime         @default(now())
  userRoles       UserRole[]
  rolePermissions RolePermission[]
  workspaceMemberships WorkspaceMembership[]
}

model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  description     String
  createdAt       DateTime         @default(now())
  rolePermissions RolePermission[]
}

model UserRole {
  userId     String
  roleId     String
  assignedAt DateTime @default(now())
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  assignedAt   DateTime   @default(now())
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Organization {
  id            String             @id @default(cuid())
  name          String
  slug          String             @unique
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  workspaces    Workspace[]
  telegramBots  TelegramBot[]
  telegramGroups TelegramGroup[]
  campaigns     Campaign[]
}

model Workspace {
  id             String               @id @default(cuid())
  organizationId String
  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  description    String?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  memberships    WorkspaceMembership[]
  telegramBots   TelegramBot[]
  telegramGroups TelegramGroup[]
  campaigns      Campaign[]
  contactImportBatches ContactImportBatch[]
  telegramUserMetas TelegramUserWorkspaceMeta[]

  @@unique([organizationId, slug])
}

model ContactImportBatch {
  id             String                   @id @default(cuid())
  workspaceId    String?
  createdByUserId String?
  sourceType     String                   @default("telegram_export")
  sourceFileName String?
  status         ContactImportBatchStatus @default(QUEUED)
  totalCount     Int
  contactsCount  Int                      @default(0)
  frequentCount  Int                      @default(0)
  processedCount Int                      @default(0)
  resolvedCount  Int                      @default(0)
  skippedCount   Int                      @default(0)
  failedCount    Int                      @default(0)
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  workspace      Workspace?               @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  createdByUser  User?                    @relation("ContactImportCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  items          ContactImportItem[]

  @@index([status, createdAt])
  @@index([workspaceId, createdAt])
}

model ContactImportItem {
  id                String                  @id @default(cuid())
  batchId           String
  kind              ContactImportItemKind
  status            ContactImportItemStatus @default(PENDING)
  phoneNumber       String?
  firstName         String?
  lastName          String?
  displayName       String?
  telegramExternalId String?
  telegramUsername  String?
  telegramType      String?
  rating            Float?
  errorMessage      String?
  attemptCount      Int                     @default(0)
  processedAt       DateTime?
  rawPayload        Json?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  batch             ContactImportBatch      @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, status, createdAt])
  @@index([phoneNumber])
  @@index([telegramExternalId])
}

model WorkspaceMembership {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  roleId      String
  isActive    Boolean   @default(true)
  assignedAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId, roleId])
  @@index([workspaceId, isActive])
}

model TelegramBot {
  id                 String         @id @default(cuid())
  organizationId     String
  workspaceId        String
  legacyConfigKey    String?        @unique
  externalId         String?        @unique
  username           String?        @unique
  displayName        String?
  label              String
  encryptedBotToken  String?
  encryptedWebhookSecret String?
  publicBaseUrl      String?
  webhookUrl         String?
  isPrimary          Boolean        @default(false)
  isActive           Boolean        @default(true)
  isVerified         Boolean        @default(false)
  webhookRegistered  Boolean        @default(false)
  lastVerifiedAt     DateTime?
  lastDiscoveredAt   DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt
  organization       Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace          Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramGroups     TelegramGroup[]
  campaigns          Campaign[]

  @@index([workspaceId, isActive])
}

model TelegramGroup {
  id                          String                          @id @default(cuid())
  organizationId              String?
  workspaceId                 String?
  telegramBotId               String?
  title                       String
  slug                        String                          @unique
  externalId                  String                          @unique
  username                    String?
  type                        String                          @default("supergroup")
  isActive                    Boolean                         @default(true)
  discoveredFrom              String?
  lastSyncedAt                DateTime?
  botMemberState              String?
  botCanDeleteMessages        Boolean                         @default(false)
  botCanRestrictMembers       Boolean                         @default(false)
  botCanInviteUsers           Boolean                         @default(false)
  botCanManageTopics          Boolean                         @default(false)
  organization                Organization?                   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace                   Workspace?                      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramBot                 TelegramBot?                    @relation(fields: [telegramBotId], references: [id], onDelete: Cascade)
  campaigns                   Campaign[]
  inviteLinks                 CampaignInviteLink[]
  moderationPolicies          ModerationPolicy[]
  moderationSettings          TelegramGroupModerationSettings?
  createdAt                   DateTime                        @default(now())

  @@index([workspaceId, isActive])
  @@index([telegramBotId, isActive])
}

model TelegramBotConfig {
  id                 String   @id @default(cuid())
  singletonKey       String   @unique @default("default")
  botExternalId      String?
  botUsername        String?
  botDisplayName     String?
  isVerified         Boolean  @default(false)
  webhookRegistered  Boolean  @default(false)
  webhookUrl         String?
  lastVerifiedAt     DateTime?
  lastDiscoveredAt   DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model TelegramGroupModerationSettings {
  id                           String   @id @default(cuid())
  telegramGroupId              String   @unique
  telegramGroup                TelegramGroup @relation(fields: [telegramGroupId], references: [id], onDelete: Cascade)
  moderationEnabled            Boolean  @default(false)
  lockUrl                      Boolean  @default(false)
  lockInvitelink               Boolean  @default(false)
  lockForward                  Boolean  @default(false)
  lockEmail                    Boolean  @default(false)
  lockPhone                    Boolean  @default(false)
  lockBot                      Boolean  @default(false)
  lockPhoto                    Boolean  @default(false)
  lockVideo                    Boolean  @default(false)
  lockDocument                 Boolean  @default(false)
  lockSticker                  Boolean  @default(false)
  lockInlineButtons            Boolean  @default(false)
  lockInlineButtonUrls         Boolean  @default(false)
  trustedUsernames             String   @default("")
  trustedExternalIds           String   @default("")
  exemptAdmins                 Boolean  @default(true)
  exemptOwners                 Boolean  @default(true)
  lockWarns                    Boolean  @default(true)
  warnLimit                    Int      @default(2)
  warnAction                   String   @default("tmute")
  warnActionDurationSeconds    Int?
  warningExpirySeconds         Int      @default(86400)
  antifloodEnabled             Boolean  @default(false)
  antifloodLimit               Int      @default(5)
  antifloodWindowSeconds       Int      @default(10)
  antifloodAction              String   @default("tmute")
  antifloodActionDurationSeconds Int    @default(600)
  antifloodDeleteAll           Boolean  @default(true)
  resetAntifloodOnRejoin       Boolean  @default(true)
  probationEnabled             Boolean  @default(false)
  probationSeconds             Int      @default(900)
  probationAction              String   @default("tmute")
  probationActionDurationSeconds Int    @default(600)
  antiRaidEnabled              Boolean  @default(false)
  antiRaidAction               String   @default("tban")
  antiRaidActionDurationSeconds Int     @default(3600)
  aiModerationEnabled          Boolean  @default(false)
  aiMode                       String   @default("off")
  aiConfidenceThreshold        Float    @default(0.85)
  aiOverrideAction             Boolean  @default(false)
  silentActions                Boolean  @default(false)
  rawLoggingEnabled            Boolean  @default(true)
  detailedLoggingEnabled       Boolean  @default(true)
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
}

model Campaign {
  id                 String                  @id @default(cuid())
  organizationId     String?
  workspaceId        String?
  telegramBotId      String?
  name               String
  channel            String
  joinRate           String
  status             CampaignStatus
  inviteCode         String                  @unique
  conversionRate     Float                   @default(0)
  createdAt          DateTime                @default(now())
  telegramGroup      TelegramGroup?          @relation(fields: [telegramGroupId], references: [id])
  telegramGroupId    String?
  organization       Organization?           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workspace          Workspace?              @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  telegramBot        TelegramBot?            @relation(fields: [telegramBotId], references: [id], onDelete: Cascade)
  assigneeUserId     String?
  assigneeUser       User?                   @relation("CampaignAssignee", fields: [assigneeUserId], references: [id], onDelete: SetNull)
  inviteLinks        CampaignInviteLink[]
  communityMembers   CommunityMember[]
  membershipSessions GroupMembershipSession[]

  @@index([assigneeUserId])
  @@index([workspaceId, status])
}

model TelegramUser {
  id                 String                   @id @default(cuid())
  externalId         String                   @unique
  username           String?
  displayName        String
  avatarInitials     String
  phoneNumber        String?
  customerSource     String?
  firstSeenAt        DateTime                 @default(now())
  lastSeenAt         DateTime                 @default(now())
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt
  communityMembers   CommunityMember[]
  membershipSessions GroupMembershipSession[]
  workspaceMetas     TelegramUserWorkspaceMeta[]

  @@index([username])
}

model TelegramUserWorkspaceMeta {
  id             String       @id @default(cuid())
  telegramUserId String
  workspaceId    String
  phoneNumber    String?
  customerSource String?
  ownerName      String?
  note           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  telegramUser   TelegramUser @relation(fields: [telegramUserId], references: [id], onDelete: Cascade)
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([telegramUserId, workspaceId])
  @@index([workspaceId, phoneNumber])
  @@index([workspaceId, customerSource])
}

model CommunityMember {
  id             String    @id @default(cuid())
  telegramUserId  String?
  telegramUser    TelegramUser? @relation(fields: [telegramUserId], references: [id], onDelete: SetNull)
  displayName    String
  avatarInitials String
  externalId     String
  username       String?
  campaignLabel  String
  campaignId     String?
  campaign       Campaign? @relation(fields: [campaignId], references: [id])
  groupTitle     String
  ownerName      String?
  note           String?
  warningCount   Int       @default(0)
  lastWarnedAt   DateTime?
  joinedAt       DateTime
  leftAt         DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @default(now()) @updatedAt
  sessions       GroupMembershipSession[]

  @@index([campaignId])
  @@index([telegramUserId])
  @@index([externalId, groupTitle])
}

model GroupMembershipSession {
  id               String           @id @default(cuid())
  telegramUserId   String
  communityMemberId String
  sessionNo        Int
  groupTitle       String
  groupExternalId  String?
  campaignId       String?
  campaignLabel    String?
  joinSource       String?
  joinedAt         DateTime
  leftAt           DateTime?
  leaveReason      String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  telegramUser     TelegramUser     @relation(fields: [telegramUserId], references: [id], onDelete: Cascade)
  communityMember  CommunityMember  @relation(fields: [communityMemberId], references: [id], onDelete: Cascade)
  campaign         Campaign?        @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([telegramUserId, groupTitle])
  @@index([communityMemberId, joinedAt])
  @@unique([communityMemberId, sessionNo])
}

model TelegramSession {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  sessionData String
  userId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model MetricCard {
  id        String    @id @default(cuid())
  label     String    @unique
  value     String
  trend     String
  tone      EventTone
  createdAt DateTime  @default(now())
}

model EventFeedItem {
  id        String    @id @default(cuid())
  title     String
  detail    String
  timeLabel String
  tone      EventTone
  createdAt DateTime  @default(now())
}

model ModerationRule {
  id        String    @id @default(cuid())
  sortOrder Int       @default(0)
  content   String
  createdAt DateTime  @default(now())
}

model ModerationPolicy {
  id                String              @id @default(cuid())
  scopeKey          String              @unique
  scopeType         ModerationScopeType
  scopeLabel        String
  autoBanSpam       Boolean             @default(true)
  muteNewMembers    Boolean             @default(false)
  muteDurationHours Int                 @default(24)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  telegramGroupId   String?
  telegramGroup     TelegramGroup?      @relation(fields: [telegramGroupId], references: [id], onDelete: Cascade)
  domains           ModerationDomain[]
  keywords          ModerationKeyword[]
}

model ModerationKeyword {
  id                 String           @id @default(cuid())
  value              String
  normalizedValue    String
  createdAt          DateTime         @default(now())
  moderationPolicyId String
  moderationPolicy   ModerationPolicy @relation(fields: [moderationPolicyId], references: [id], onDelete: Cascade)

  @@unique([moderationPolicyId, normalizedValue])
}

model ModerationDomain {
  id                 String             @id @default(cuid())
  value              String
  normalizedValue    String
  mode               ModerationListMode @default(BLOCK)
  createdAt          DateTime           @default(now())
  moderationPolicyId String
  moderationPolicy   ModerationPolicy   @relation(fields: [moderationPolicyId], references: [id], onDelete: Cascade)

  @@unique([moderationPolicyId, normalizedValue, mode])
}

model SpamEvent {
  id              String       @id @default(cuid())
  source          String
  eventType       String
  actorUsername   String?
  actorExternalId String?
  groupTitle      String
  groupExternalId String?
  campaignLabel   String?
  messageText     String?
  messageExternalId String?
  matchedRules    Json
  ruleScore       Int
  aiScore         Int?
  finalScore      Int
  aiLabel         String?
  aiReason        String?
  decision        SpamDecision
  manualDecision  SpamDecision?
  manualNote      String?
  reviewedAt      DateTime?
  actionLogs      Json?
  lastActionAt    DateTime?
  createdAt       DateTime     @default(now())
}

model ModerationActionJob {
  id              String   @id @default(cuid())
  source          String
  status          String   @default("PENDING")
  eventType       String
  actionVariant   String
  spamEventId     String?
  chatId          String
  userId          String
  groupTitle      String?
  actorExternalId String?
  note            String?
  commandText     String?
  executeAt       DateTime @default(now())
  expireAt        DateTime
  completedAt     DateTime?
  lastError       String?
  payload         Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, expireAt])
  @@index([chatId, userId, actionVariant])
}

model RoadmapPhase {
  id        String         @id @default(cuid())
  name      String         @unique
  outcome   String
  sortOrder Int            @default(0)
  tasks     RoadmapTask[]
  createdAt DateTime       @default(now())
}

model RoadmapTask {
  id             String       @id @default(cuid())
  content        String
  sortOrder      Int          @default(0)
  roadmapPhase   RoadmapPhase @relation(fields: [roadmapPhaseId], references: [id], onDelete: Cascade)
  roadmapPhaseId String
  createdAt      DateTime     @default(now())
}

model AutopostCapability {
  id        String   @id @default(cuid())
  title     String   @unique
  detail    String
  createdAt DateTime @default(now())
}

model AutopostTarget {
  id          String                 @id @default(cuid())
  platform    AutopostTargetPlatform
  externalId  String
  displayName String
  status      String                 @default("CONNECTED")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  schedules   AutopostSchedule[]

  @@unique([platform, externalId])
}

model AutopostSchedule {
  id                String                 @id @default(cuid())
  title             String
  message           String
  frequency         String
  scheduledFor      DateTime?
  status            AutopostScheduleStatus @default(DRAFT)
  mediaUrl          String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  targetId          String
  target            AutopostTarget         @relation(fields: [targetId], references: [id], onDelete: Cascade)
  logs              AutopostLog[]
}

model AutopostLog {
  id             String                 @id @default(cuid())
  scheduleId     String
  schedule       AutopostSchedule       @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  status         AutopostDeliveryStatus @default(PENDING)
  detail         String?
  externalPostId String?
  createdAt      DateTime               @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
}

model SystemLog {
  id        String         @id @default(cuid())
  level     SystemLogLevel @default(INFO)
  scope     String
  action    String
  message   String
  detail    String?
  payload   Json?
  createdAt DateTime       @default(now())
}

model CampaignInviteLink {
  id               String            @id @default(cuid())
  campaignId       String
  campaign         Campaign          @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  telegramGroupId  String?
  telegramGroup    TelegramGroup?    @relation(fields: [telegramGroupId], references: [id], onDelete: SetNull)
  externalInviteId String?
  inviteUrl        String            @unique
  label            String
  memberLimit      Int?
  createsJoinRequest Boolean         @default(false)
  status           String            @default("ACTIVE")
  expireAt         DateTime?
  createdAt        DateTime          @default(now())
  events           InviteLinkEvent[]
}

model InviteLinkEvent {
  id              String          @id @default(cuid())
  inviteLinkId    String?
  inviteLink      CampaignInviteLink? @relation(fields: [inviteLinkId], references: [id], onDelete: SetNull)
  eventType       InviteEventType
  actorExternalId String?
  actorUsername   String?
  groupTitle      String
  groupExternalId String?
  detail          String?
  createdAt       DateTime        @default(now())
}
